# Python bytecode cache (generated by the repo's standard-library scripts)
__pycache__/
*.py[cod]

# Node — the site generator has no dependencies, but npm may still create this
node_modules/

# Generated platform install packs (scripts/build_platform_packs.py)
dist/

# Generated static skill catalog (site/generate.mjs) — built and deployed
# by .github/workflows/deploy-pages.yml on every push to main.
site/public/
